# Database
DB_HOST=your-rds-endpoint
DB_PORT=3306
DB_NAME=washerproject
DB_USER=your-username
DB_PASS=your-password

# Email (SMTP)
SMTP_FROM=your-sender@gmail.com
SMTP_PASSWORD=your-app-password

# Manager
MANAGER_EMAIL=your-manager@example.com

# CORS
CORS_ORIGIN=http://localhost:3000

# YoLink sensor integration (leave blank to disable sensor mode)
YOLINK_CLIENT_ID=your-yolink-client-id
YOLINK_SECRET_KEY=your-yolink-secret-key
YOLINK_HOME_ID=your-yolink-home-id

# RabbitMQ (docker-compose default: localhost/guest/guest)
# For cloud: set host to your AWS MQ / CloudAMQP endpoint
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
